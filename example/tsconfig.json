{
    "compilerOptions": {
        "target": "es2024",
        "module": "node20",
        "moduleResolution": "node16",
        
        "strict": true,
        "noEmit": true,
        "sourceMap": true,
        // "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": false,

        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": "./src",
        "paths": {
            "@lib/*": [ "./lib-old/*", "./lib/*" ]
        }
    },
    "exclude": [
        "**/*.test.ts"
    ]
}