{
    "compilerOptions": {
        "target": "es2024",
        "module": "node20",
        "moduleResolution": "node16",
        
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "strict": true,
        "noEmit": true,

        "rootDir": "./src",
        "outDir": "./dist",
        "paths": {
            "@lib/*": [ "./src/lib-old/*", "./src/lib/*" ]
        },
        "types": ["node"]
    },
    "exclude": [
        "**/*.test.ts"
    ]
}