{
    "compilerOptions": {
        "target": "ES2024",
        "module": "node20",
        "moduleResolution": "Node16",
        
        "strict": true,
        "noEmit": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,

        "rootDir": "./src",
        "baseUrl": "./src",
        "paths": {
            "@lib/*": [ "./lib-old/*", "./lib/*" ]
        }
    }
}