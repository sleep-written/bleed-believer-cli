{
  "name": "@bleed-believer/cli",
  "version": "0.0.5-alpha.0",
  "description": "A ts-node replacement with path alias resolution and SWC under the hood",
  "type": "module",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "banner.txt"
  ],
  "exports": {
    ".": {
      "import": [
        "./dist/index.js",
        "./src/index.ts"
      ]
    }
  },
  "bin": {
    "@bleed-believer/path-alias": "./dist/cli.js",
    "bleed": "./dist/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "test:only": "node --test-only",
    "check": "tsc --noEmit",
    "build": "node ./src/cli.ts build -c tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sleep-written/bleed-believer-cli.git"
  },
  "keywords": [
    "ts",
    "swc",
    "typescript",
    "tsnode",
    "tsconfig",
    "ts-node",
    "ts-config",
    "tsconfig.json",
    "path",
    "alias",
    "mapping"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "sleep-written",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "bugs": {
    "url": "https://github.com/sleep-written/bleed-believer-cli/issues"
  },
  "homepage": "https://github.com/sleep-written/bleed-believer-cli#readme",
  "dependencies": {
    "json5": "^2.2.3",
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  }
}
