{
  "name": "@bleed-believer/cli",
  "version": "0.1.1",
  "description": "A ts-node replacement with path alias resolution and SWC under the hood",
  "type": "module",
  "module": "./src/index.ts",
  "files": [
    "dist",
    "banner.txt"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "@bleed-believer/path-alias": "./src/cli.ts",
    "bleed": "./src/cli.ts"
  },
  "scripts": {
    "test": "node --test",
    "check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sleep-written/bleed-believer-cli.git"
  },
  "keywords": [
    "ts",
    "swc",
    "typescript",
    "tsnode",
    "tsconfig",
    "ts-node",
    "ts-config",
    "tsconfig.json",
    "path",
    "alias",
    "mapping"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "sleep-written",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "bugs": {
    "url": "https://github.com/sleep-written/bleed-believer-cli/issues"
  },
  "homepage": "https://github.com/sleep-written/bleed-believer-cli#readme",
  "dependencies": {
    "@swc/core": "^1.15.21",
    "chalk": "^5.6.2",
    "json5": "^2.2.3",
    "tslog": "^4.10.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "typescript": "^6.0.2"
  }
}
